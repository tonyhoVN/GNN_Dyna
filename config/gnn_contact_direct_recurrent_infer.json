{
  "data": {
    "data_dir": "data",
    "file_glob": "*time_data.npz",
    "percent": 50
  },
  "split": {
    "train": 0.85,
    "valid": 0.15,
    "test": 0.0
  },
  "model": {
    "type": "direct_recurrent",
    "hidden_dim": 64,
    "node_encoder": {
      "feat_dim": 6,
      "history_len": 5,
      "lstm_layers": 1,
      "use_mass": true,
      "use_pos": false,
      "layer_norm": true
    },
    "edge_encoder": {
      "feat_dim": 7,
      "layer_norm": true
    },
    "gnn_topology": {
      "n_gnn_layers": 10,
      "shared_layers": true,
      "layer_norm": false
    },
    "gnn_surface": {
      "enabled": true,
      "distance_threshold": 22.0,
      "layer_norm": false
    },
    "decoder": {
      "out_dim": 6,
      "pred_horizon": 1
    }
  },
  "training": {
    "batch_size": 12,
    "learning_rate": 0.0001,
    "epochs": 100,
    "save_every": 10
  }
}
